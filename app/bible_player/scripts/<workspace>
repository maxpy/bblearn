import 'dart:async';
import 'package:flutter_riverpod/flutter_riverpod.dart';
import '../services/audio_service.dart';
import '../models/subtitle_entry.dart';
import '../services/subtitle_service.dart';

/// Provider for the audio service singleton.
final audioServiceProvider = Provider<AudioService>((ref) {
  final service = AudioService();
  ref.onDispose(() => service.dispose());
  return service;
});

/// Provider for the subtitle service.
final subtitleServiceProvider = Provider<SubtitleService>((ref) {
  return SubtitleService();
});

/// Audio playing state.
final isPlayingProvider = StreamProvider<bool>((ref) {
  final service = ref.watch(audioServiceProvider);
  return service.playingStream;
});

/// Current position stream.
final positionProvider = StreamProvider<Duration>((ref) {
  final service = ref.watch(audioServiceProvider);
  return service.positionStream;
});

/// Total duration stream.
final durationProvider = StreamProvider<Duration?>((ref) {
  final service = ref.watch(audioServiceProvider);
  return service.durationStream;
});

/// Current active subtitle based on audio position.
final activeSubtitleProvider = Provider<SubtitleEntry?>((ref) {
  final subtitleService = ref.watch(subtitleServiceProvider);
  final posAsync = ref.watch(positionProvider);

  return posAsync.when(
    data: (pos) => subtitleService.activeAt(pos.inMilliseconds / 1000.0),
    loading: () => null,
    error: (_, __) => null,
  );
});

/// Playback speed.
final playbackSpeedProvider = StateProvider<double>((ref) => 1.0);
